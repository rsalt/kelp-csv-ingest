PORT=3000
# Paste External Database URL from Render → PostgreSQL → Connect (one line, no spaces).
DATABASE_URL=postgresql://user:password@hostname.example.com:5432/database
# Local Postgres only:
# DATABASE_SSL=false
# Optional: server-side CSV path for POST /api/ingest
# CSV_FILE_PATH=./data/sample.csv
# INGEST_ON_START=false
